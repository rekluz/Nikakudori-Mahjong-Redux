<resources>
    <!-- 1. The Splash Screen Theme -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/dark_blue</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.NikakudoriFresh</item>
    </style>

    <!-- 2. The Main Game Theme -->
    <!-- Changed parent to a more robust Material3 reference -->
    <style name="Theme.NikakudoriFresh" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/dark_blue</item>
        <item name="android:windowNoTitle">true</item>

        <!-- S24 Display Cutout Optimization -->
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>
</resources>